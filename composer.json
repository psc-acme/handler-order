{
    "name": "psc-acme/handler-order",
    "description": "Package handler-order for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\HandlerOrder\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/messenger": "^7.0",
        "symfony/lock": "^7.0",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.0",
        "phpstan/phpstan": "^1.0",
        "rector/rector": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}